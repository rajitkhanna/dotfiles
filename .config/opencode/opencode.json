{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwriter": {
      "type": "local",
      "command": ["npx", "-y", "playwriter@latest"],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-115c60af-93d5-45a7-b261-5a2f48a3b1ca"
      },
      "enabled": false
    },
    "nia": {
      "type": "remote",
      "url": "https://apigcp.trynia.ai/mcp",
      "headers": {
        "Authorization": "Bearer nk_DjdmYgJFoapbEFHY5z6p6u33LOwk3NAU"
      },
      "enabled": false
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "headers": {
        "Authorization": "Bearer 58917652-3123-4713-9db1-006c55277b63"
      },
      "enabled": false
    },
    "remarkable": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "rmc",
        "--with",
        "cairosvg",
        "remarkable-mcp",
        "--ssh"
      ],
      "environment": {
        "REMARKABLE_SSH_HOST": "remarkable",
        "REMARKABLE_OCR_BACKEND": "google",
        "GOOGLE_VISION_API_KEY": "AIzaSyCZ3jrEHjdqb38THIF_CZwptQjhYAsUIfc"
      },
      "enabled": false
    },
    "circleback": {
      "type": "remote",
      "url": "https://app.circleback.ai/api/mcp",
      "enabled": true
    }
  },
  "instructions": [
    "apps/*/AGENTS.md",
    "apps/*/src/**/AGENTS.md",
    "packages/*/AGENTS.md",
    "AGENTS.md"
  ],
  "formatter": {
    "prettier": {
      "command": ["bunx", "prettier", "--write", "$FILE"],
      "environment": {
        "NODE_ENV": "development"
      },
      "extensions": [".js", ".ts", ".jsx", ".tsx"]
    }
  },
  "permission": {
    "external_directory": {
      "~/Github/**": "allow",
      "~/tmp/**": "allow"
    }
  },
  "plugin": [
    "@honcho-ai/opencode-honcho"
  ]
}
